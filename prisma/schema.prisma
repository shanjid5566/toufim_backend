generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

//  User model

model User {
  id                String  @id @default(uuid())
  fullName          String
  email             String  @unique
  password          String  // For authentication
  phone             String
  instagramUsername String?
  totalSpent        Decimal @default(0) @db.Decimal(10, 2)

  orders    Order[]
  coupons   Coupon[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin model

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Service model
enum ServiceStatus {
  LIVE
  MAINTENANCE
}

model Service {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String        @db.Text
  basePrice   Decimal       @db.Decimal(10, 2)
  category    String
  images      String[]
  status      ServiceStatus @default(LIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Order Lead model

enum LeadStatus {
  PENDING
  CONTACTED
  COMPLETED
  QUOTED
  CLOSED
}

model Lead {
  id              String     @id @default(uuid())
  fullName        String
  email           String
  phone           String
  serviceType     String
  address         String     @db.Text
  projectDetails  String     @db.Text
  referenceImages String[]
  status          LeadStatus @default(PENDING)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// Giveaway model

enum GiveawayStatus {
  ACTIVE
  COMPLETED
  DRAFT
}

model Giveaway {
  id           String         @id @default(uuid())
  title        String
  description  String         @db.Text
  totalTickets Int
  ticketsSold  Int            @default(0)
  drawDate     DateTime
  bannerImage  String?
  status       GiveawayStatus @default(ACTIVE)

  packages       TicketPackage[]
  orders         Order[]
  coupons        Coupon[]
  winnerCouponId String?         @unique
  winnerCoupon   Coupon?         @relation("GiveawayWinner", fields: [winnerCouponId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Ticket Package model
model TicketPackage {
  id             String  @id @default(uuid())
  title          String
  couponCount    Int     // Number of tickets in this package
  price          Decimal @db.Decimal(10, 2) // Total price for this package
  basePrice      Decimal @db.Decimal(10, 2) // Individual ticket price (for save % calculation)
  savePercentage Decimal @db.Decimal(5, 2) @default(0) // Calculated save percentage
  badgeText      String?

  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id])
  orders     Order[]

  createdAt DateTime @default(now())
}

// Voucher model

enum VoucherType {
  PERCENTAGE
  FLAT
}

enum VoucherStatus {
  ACTIVE
  EXPIRED
}

model Voucher {
  id             String        @id @default(uuid())
  code           String        @unique // e.g., SAVE10
  discountType   VoucherType   @default(PERCENTAGE)
  discountValue  Decimal       @db.Decimal(10, 2)
  usageLimit     Int
  usedCount      Int           @default(0)
  expirationDate DateTime
  status         VoucherStatus @default(ACTIVE)

  orders Order[]

  createdAt DateTime @default(now())
}

// Order model
enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Order {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  giveawayId String
  giveaway   Giveaway      @relation(fields: [giveawayId], references: [id])
  packageId  String
  package    TicketPackage @relation(fields: [packageId], references: [id])
  voucherId  String?
  voucher    Voucher?      @relation(fields: [voucherId], references: [id])

  totalAmount     Decimal     @db.Decimal(10, 2)
  paymentIntentId String?     @unique // Stripe reference
  status          OrderStatus @default(PENDING)

  coupons   Coupon[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Coupon model

enum CouponStatus {
  VALID
  VOID
}

model Coupon {
  id         String       @id @default(uuid())
  couponCode String       @unique
  status     CouponStatus @default(VALID)

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id])

  wonGiveaway Giveaway? @relation("GiveawayWinner")

  createdAt DateTime @default(now())
}


