										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"code\": \"AMBER-FALL-24\",\n  \"discountType\": \"PERCENTAGE\",\n  \"discountValue\": 20,\n  \"usageLimit\": 100,\n  \"expirationDate\": \"2026-12-31\",\n  \"status\": \"ACTIVE\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/admin/vouchers",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"admin",
										"vouchers"
									]
								},
								"description": "Create a new voucher. Default status is ACTIVE. Use status='DRAFT' to save without activating. Returns 409 if a voucher with the same code already exists (user-friendly error: 'A voucher with this code already exists'). discountType: PERCENTAGE (1-100) or FLAT (amount in currency). Usage tracking: usedCount starts at 0 and increments with each order, auto-expires when usedCount reaches usageLimit."
							},
							"response": []
						},
						{
							"name": "Validate Voucher",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [
										{
											"key": "token",
											"value": "{{jwt_token}}",
											"type": "string"
										}
									]
								},
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"code\": \"AMBER-FALL-24\",\n  \"orderAmount\": 500,\n  \"consume\": false\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/admin/vouchers/validate",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"admin",
										"vouchers",
										"validate"
									]
								},
								"description": "Validate a voucher code. Checks: 1) Voucher exists and is ACTIVE, 2) Not expired, 3) Has usage remaining. Returns discount calculation.\\n\\nPARAMETERS:\\n- consume: false (default) = Only validate, don't increment usedCount (for cart preview)\\n- consume: true = Validate AND increment usedCount (for order completion testing)\\n\\nEXAMPLES:\\n1. Cart preview: {consume: false} - shows discount without consuming\\n2. Test order: {consume: true} - increments usedCount and auto-expires when limit reached"
							},
							"response": []
						},
