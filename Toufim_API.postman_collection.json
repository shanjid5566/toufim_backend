		{
			"name": "Public",
			"item": [
				{
					"name": "Vouchers",
					"item": [
						{
							"name": "Validate Voucher",
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"code\": \"AMBER-FALL-24\",\n  \"orderAmount\": 500\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/vouchers/validate",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"vouchers",
										"validate"
									]
								},
								"description": "Validate a voucher code (PUBLIC - No authentication required).\\n\\nCHECKS:\\n1. Voucher exists and is ACTIVE\\n2. Not expired (expirationDate)\\n3. Has remaining uses (usedCount < usageLimit)\\n\\nRETURNS:\\n- voucherCode (send this CODE when creating order, not an ID)\\n- Discount calculation\\n- Final amount after discount\\n- Remaining uses\\n\\nIMPORTANT:\\n✅ This endpoint only PREVIEWS the discount\\n❌ Does NOT consume the voucher (usedCount stays the same)\\n\\nVOUCHER CONSUMPTION:\\nHappens automatically server-side when:\\n1. Customer completes payment\\n2. Frontend sends voucherCode (not ID) to order endpoint\\n3. Backend validates, creates order, and consumes voucher automatically\\n\\nNo need to call this API again after payment!"
							},
							"response": []
						}
					],
					"description": "Public voucher endpoints - no authentication required"
				}
			],
			"description": "Public endpoints accessible to all users without authentication"
		}
