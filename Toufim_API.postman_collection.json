								"body": {
									"mode": "raw",
									"raw": "{\n  \"packages\": [\n    {\n      \"couponCount\": 50,\n      \"price\": 1200\n    },\n    {\n      \"couponCount\": 100,\n      \"price\": 2000\n    }\n  ]\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/admin/giveaways/:giveawayId/packages",
