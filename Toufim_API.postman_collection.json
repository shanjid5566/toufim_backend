									"variable": [
										{
											"key": "giveawayId",
											"value": "",
											"description": "Giveaway UUID"
										}
									]
								},
								"description": "Update giveaway details (title, description, drawDate, drawTime). Does not update ticket packages."
							},
							"response": []
						},
						{
							"name": "Add Ticket Packages",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [
										{
											"key": "token",
											"value": "{{jwt_token}}",
											"type": "string"
										}
