{
	"info": {
		"_postman_id": "toufim-api-collection",
		"name": "Toufim API",
		"description": "Complete API collection for Toufim - Admin authentication and giveaway management",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "admin",
			"item": [
				{
					"name": "auth",
					"item": [
						{
							"name": "Login Admin",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"if (pm.response.code === 200) {",
											"    var jsonData = pm.response.json();",
											"    pm.environment.set(\"jwt_token\", jsonData.token);",
											"    console.log(\"JWT Token saved:\", jsonData.token);",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"email\": \"admin@toufim.com\",\n  \"password\": \"admin123\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/admin/auth/login",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"admin",
										"auth",
										"login"
									]
								},
								"description": "Login with admin credentials. Returns JWT token valid for 24 hours. Token is automatically saved to environment variable."
							},
							"response": []
						},
						{
							"name": "Get Admin Profile",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [
										{
											"key": "token",
											"value": "{{jwt_token}}",
											"type": "string"
										}
									]
								},
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/api/admin/auth/me",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"admin",
										"auth",
										"me"
									]
								},
								"description": "Get current admin profile. Requires JWT authentication."
							},
							"response": []
						},
						{
							"name": "Change Password",
							"request": {
								"auth": {
									"type": "bearer",
									"bearer": [
										{
											"key": "token",
											"value": "{{jwt_token}}",
											"type": "string"
										}
									]
								},
								"method": "PUT",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"currentPassword\": \"admin123\",\n  \"newPassword\": \"newpassword123\"\n}"
								},
								"url": {
									"raw": "{{base_url}}/api/admin/auth/change-password",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"api",
										"admin",
										"auth",
										"change-password"
									]
								},
								"description": "Change admin password. Requires JWT authentication."
							},
							"response": []
						}
					],
					"description": "Admin authentication endpoints - register, login, profile, and password management"
				},
				{
