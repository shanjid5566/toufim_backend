								"body": {
									"mode": "raw",
									"raw": "{\n  \"title\": \"iPhone 15 Pro Max Giveaway - Updated\",\n  \"description\": \"Updated description - Win the latest iPhone 15 Pro Max\",\n  \"drawDate\": \"2026-05-20\",\n  \"drawTime\": \"20:00\"\n}"
